import { Button, TextEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";

export component UpReadConfAll inherits Window {
    init => {
        Theme.is-dark = root.dark-mode;
    }
    changed dark_mode => {
        Theme.is-dark = root.dark-mode;
    }
    background: Theme.background;
    title: "All your configurate";
    height: 400px;
    width: 600px;
    in-out property <bool> dark_mode;
    in-out property <string> all_config; // переменная для записи всех доменов из конфига и передачи из в TextEdit

    callback save_config(); // событие для сохранения новых доменов

    Rectangle {
        TextEdit {
            width: parent.width;
            height: parent.height - 42px;
            y: 0;
            text <=> root.all_config;
        }
        Button {
            x: 440px;
            y: 363px;
            text: "Сохранится и выйти";
            clicked => {
                root.save_config();
            }
        }
    }
}
